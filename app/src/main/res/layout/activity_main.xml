<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- Título Principal -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dolar Calculator"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_main"
        android:layout_marginTop="30dp"
         />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/text_color_main"/>


        <Switch
            android:id="@+id/switchDivisa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="36dp"
            android:text="$"
            android:textSize="20dp"
            android:textColor="@color/text_color_main"
            android:textStyle="bold"
            />
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:padding="16dp"
        app:cardBackgroundColor="@color/card_background"
        android:layout_gravity="center"


        >

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
           android:gravity="center"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="16dp">
    <!-- Fecha de Actualización -->
    <TextView
        android:id="@+id/tvFecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando..."
        android:textSize="14sp"
        android:textColor="@color/text_color_main"
        android:layout_marginTop="5dp"

       />



 ->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BCV (Oficial)"
        android:textSize="16sp"
        android:textColor="@color/text_color_main"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvBcv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bs. 0,00"
        android:textSize="40sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/text_color_bcv" />

    <!-- Espacio entre precios -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- Sección Dólar Paralelo -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Paralelo (Monitor)"
        android:textSize="16sp"
        android:textColor="@color/text_color_main"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvParalelo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bs. 0,00"
        android:textSize="40sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/text_color_paralelo" />

    <View
        android:layout_width="match_parent"
        android:layout_height="30dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calculadora de Cambios"
        android:textStyle="bold"
        android:textColor="@color/text_color_main"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/etCalculator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0.00"
        android:textColorHint="#2E7D32"
        android:inputType="numberDecimal"
        android:textAlignment="center"
        android:layout_marginTop="10dp" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvResultBcv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BCV: -- "
        android:textStyle="bold"
        android:textSize="16dp"
        android:textColor="@color/text_color_main"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/tvResultParalelo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Paralelo: -- "
        android:textSize="16dp"
        android:textColor="@color/text_color_main"
        android:textStyle="bold"
        android:layout_marginTop="5dp" />


    <!-- Botón de actualización -->
    <Button
        android:id="@+id/btnUpdate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="ACTUALIZAR"
        android:textSize="18sp"
        android:backgroundTint="#1976D2"
        android:textColor="@color/white" />

</LinearLayout>