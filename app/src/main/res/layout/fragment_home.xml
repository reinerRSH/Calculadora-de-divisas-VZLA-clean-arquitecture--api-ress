<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_home"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <!-- Título Principal -->
    <TextView
        android:id="@+id/tvTitulo"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dolar Calculator"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_main"
        android:layout_marginTop="30dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.constraintlayout.utils.widget.ImageFilterView
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/share"
            android:background="@drawable/background_share"
            />


        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs"
            android:textSize="18dp"
            android:textStyle="bold"
            android:textColor="@color/text_color_main"/>


        <Switch
            android:id="@+id/switchDivisa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:ignore="UseSwitchCompatOrMaterialXml"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="36dp"
            android:text="$"
            android:textSize="20dp"
            android:textColor="@color/text_color_main"
            android:textStyle="bold"
            />
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        android:padding="16dp"
        app:cardBackgroundColor="@color/card_background"
        android:layout_gravity="center"


        >

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_margin="12dp"
            android:padding="16dp">
            <!-- Fecha de Actualización -->
            <TextView
                android:id="@+id/tvFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textSize="14sp"
                android:textColor="@color/text_color_main"
                android:layout_marginTop="5dp"

                />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="BCV (Oficial)"
                android:textSize="16sp"
                android:textColor="@color/text_color_main"
                android:gravity="center" />
            ->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:elevation="0dp"
                android:padding="8dp"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@color/colorBackgraundTexto">





                <TextView
                    android:id="@+id/tvBcv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bs. 0,00"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/text_color_bcv" />



            </androidx.cardview.widget.CardView>




            <!-- Espacio entre precios -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Sección Dólar Paralelo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="USDT (Referencia)"
                android:textSize="16sp"
                android:textColor="@color/text_color_main"
                android:gravity="center" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:elevation="0dp"
                android:padding="8dp"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@color/colorBackgraundTexto">

                <TextView
                    android:id="@+id/tvParalelo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bs. 0,00"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/text_color_paralelo" />
            </androidx.cardview.widget.CardView>



            <View
                android:layout_width="match_parent"
                android:layout_height="30dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculadora de Cambios"
                android:textStyle="bold"
                android:textColor="@color/text_color_main"
                android:textSize="16sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                android:elevation="0dp"
                android:padding="8dp"
                android:layout_margin="8dp"
                app:cardBackgroundColor="@color/colorBackgraundTexto">

                <EditText
                    android:id="@+id/etCalculator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="1.00$"
                    android:textColorHint="#2E7D32"
                    android:inputType="numberDecimal"
                    android:textAlignment="center"
                    android:layout_marginTop="10dp" />

            </androidx.cardview.widget.CardView>


                />


        </LinearLayout>

    </androidx.cardview.widget.CardView>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/RegistroPagM"
        android:backgroundTint="@color/colorBackgraundTexto"
        android:layout_gravity="center_horizontal"
        android:text="Registro de Pago Móvil"
        android:textColor="@color/text_color_main"
        android:textSize="16sp"
        android:layout_marginTop="10dp"
        />





</LinearLayout>